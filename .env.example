# ============================================
# ADREANO — VARIÁVEIS DE AMBIENTE
# ============================================
# Copie este arquivo para .env (mesma pasta) e preencha com os valores reais.
# NUNCA commite o .env. NUNCA cole valores destes campos em chat.
# ============================================

# ----- META MARKETING API -----
# Token gerado em business.facebook.com → Usuários do sistema
# Permissões: ads_management, ads_read, pages_read_engagement, pages_manage_ads
META_ACCESS_TOKEN=

# ID da conta de anúncios (formato: act_xxxxxxxxxxxxxxx)
META_AD_ACCOUNT_ID=

# ID do Pixel (público, seguro deixar visível)
META_PIXEL_ID=412518964606895

# ID do App da Meta (developers.facebook.com → Seus apps)
META_APP_ID=

# Secret do App (developers.facebook.com → Configurações Básicas)
META_APP_SECRET=

# ID da página do Facebook que veicula os anúncios
META_PAGE_ID=

# ID da conta business do Instagram (opcional)
META_INSTAGRAM_ACCOUNT_ID=

# ----- META CONVERSIONS API (CAPI) -----
# Token específico para enviar eventos server-side (pode ser o mesmo do META_ACCESS_TOKEN
# se este tiver permissão, ou um token dedicado de Sistema gerado para CAPI)
META_CAPI_ACCESS_TOKEN=

# Test Event Code (gerado em Events Manager → Test Events) — usar só durante testes
# META_TEST_EVENT_CODE=TEST12345

# ----- SYMPLA -----
# URL pública do evento na Sympla (sem trailing slash)
SYMPLA_EVENT_URL=https://www.sympla.com.br/evento/diagnostico-de-estrutura-mental-do-empresario-e-lider-de-alta-performance/3504059

# Token/segredo para validar webhooks recebidos da Sympla
# (gerado quando você cria o webhook no painel do Sympla)
SYMPLA_WEBHOOK_SECRET=

# ----- CLOUDFLARE (apenas para deploy via CLI) -----
# Account ID do Cloudflare (dash.cloudflare.com → canto direito)
CLOUDFLARE_ACCOUNT_ID=

# API Token com permissões de Pages + D1 (cria em dash.cloudflare.com/profile/api-tokens)
CLOUDFLARE_API_TOKEN=
